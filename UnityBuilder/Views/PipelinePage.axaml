<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:conv="using:UnityBuilder.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UnityBuilder.Views.PipelinePage"
             xmlns:vm="using:UnityBuilder.ViewModels"
             x:DataType="vm:PipelinePageViewModel">
    <UserControl.Resources>
        <conv:AndBoolConverter x:Key="AndBoolConverter"/>
        <conv:NodeStateToBrushConverter x:Key="NodeStateToBrushConverter"/>
    </UserControl.Resources>
    <Grid RowDefinitions="*, Auto">
        <Grid Grid.Row="0" Margin="16,16,16,8">
            <Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" MinWidth="200"/>
				<ColumnDefinition Width="8"/>
				<ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Visible">
                    <Canvas Background="Transparent"
                            Name="pipelineCanvas">

                    </Canvas>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWestEast"/>

            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Grid.Column="2"
                    Padding="14">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding SelectedNodeId}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMuted}"/>

                    <AvaloniaEdit:TextEditor Text=""
                               ShowLineNumbers="True"
                               Name="avaloniaTextEditor"
                               Grid.Row="1"
                               Margin="0,6,0,0"/>

                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Margin="16,0,16,16">

            <Grid ColumnDefinitions="*,Auto">

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding StateResult}"
                               VerticalAlignment="Center"
                               Foreground="{Binding StateResult, Converter={StaticResource NodeStateToBrushConverter}}"/>
                    <TextBlock Text="{Binding WorkingTime}"
								   FontSize="11"
                                   VerticalAlignment="Center"
								   Foreground="Gray" />
                </StackPanel>
                
                
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="12">

                    <Button Content="← Back" Width="120"
                            Click="Button1_Click"
                            IsEnabled="{Binding !IsPipelineRun}"/>
                    <Button Content="Cancel"
                            Click="CancelButton_Click"
                            Width="160"
                            IsEnabled="{Binding IsPipelineRun}"/>

                </StackPanel>

            </Grid>

        </Border>
    </Grid>
</UserControl>
