<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:conv="using:UnityBuilder.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UnityBuilder.Views.PipelinePage"
             xmlns:vm="using:UnityBuilder.ViewModels"
             x:DataType="vm:PipelinePageViewModel">
    <UserControl.Resources>
        <conv:AndBoolConverter x:Key="AndBoolConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid ColumnDefinitions="*,*" Margin="6,40,6,90">
            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <Canvas Width="1000"
                            Height="700"
                            Background="Transparent"
                            Name="pipelineCanvas">
            
                    </Canvas>
                </ScrollViewer>
            </Border>
        
            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    Padding="14">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding SelectedNodeId}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMuted}"/>
					<!--<ScrollViewer Grid.Row="1"
				             Margin="0,6,0,0"
						VerticalScrollBarVisibility="Auto">
						<TextBox Watermark="info" 
                             Text="{Binding SelectedNodeOutput}"
                              Margin="0,0,16,0"
							 IsReadOnly="True"
							 TextWrapping="Wrap"
							 
							 HorizontalAlignment="Stretch"
							 VerticalAlignment="Stretch"
				             />
					</ScrollViewer>-->
					
					<AvaloniaEdit:TextEditor Text=""
                           ShowLineNumbers="True"
											 Name="avaloniaTextEditor"
											 Grid.Row="1"
				             Margin="0,6,0,0"/>
                    
                </Grid>
            </Border>
        </Grid>

        <!-- ACTION BAR -->
        <Border Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="12"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Padding="14"
                Margin="6">

            <Grid ColumnDefinitions="*,Auto">

                <TextBlock Text="Running..."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WarningColor}">
                    <TextBlock.IsVisible>
                        <MultiBinding Converter="{StaticResource AndBoolConverter}">
                            <Binding Path="IsRunning"/>
                            <Binding Path="!IsDone"/>
                        </MultiBinding>
                    </TextBlock.IsVisible>
                </TextBlock>
                <TextBlock Text="Stopped"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DangerColor}">
                    <TextBlock.IsVisible>
                        <MultiBinding Converter="{StaticResource AndBoolConverter}">
                            <Binding Path="!IsRunning"/>
                            <Binding Path="!IsDone"/>
                        </MultiBinding>
                    </TextBlock.IsVisible>
                </TextBlock>
                <TextBlock Text="Done"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SuccessColor}">
                    <TextBlock.IsVisible>
                        <MultiBinding Converter="{StaticResource AndBoolConverter}">
                            <Binding Path="!IsRunning"/>
                            <Binding Path="IsDone"/>
                        </MultiBinding>
                    </TextBlock.IsVisible>
                </TextBlock>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="12">

                    <Button Content="Previous page" Width="120"
                            IsEnabled="{Binding !IsRunning}"
                            Click="Button1_Click"/>
                    <Button Content="Cancel"
                            IsEnabled="{Binding IsRunning}"
                            Width="160"/>

                </StackPanel>

            </Grid>
            
        </Border>
    </Grid>
</UserControl>
