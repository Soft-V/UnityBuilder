<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:UnityBuilder.ViewModels"
             xmlns:conv="using:UnityBuilder.Converters"
             mc:Ignorable="d"
             x:Class="UnityBuilder.Views.MainView"
             x:DataType="vm:MainViewModel">

    <UserControl.Resources>
        <conv:AndBoolConverter x:Key="AndBoolConverter"/>
    </UserControl.Resources>

    <ScrollViewer Background="{DynamicResource AppBackground}">

        <StackPanel Margin="32"
                    Spacing="28"
                    MaxWidth="820"
                    HorizontalAlignment="Center">

            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                <TextBlock Text="Unity Builder"
                           FontSize="32"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>

                <!-- THEME BUTTON -->
                <Button Grid.Column="1"
                        Content="Theme"
                        Padding="12,6"
                        Command="{Binding SwitchThemeCommand}"
                        Background="{DynamicResource SurfaceBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        Foreground="{DynamicResource TextPrimary}"/>

            </Grid>

            <!-- CARD: PROJECT -->
            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">

                <StackPanel Spacing="10">

                    <TextBlock Text="Project settings"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>

                    <TextBox Width="460" Watermark="Unity path"/>
                    <TextBox Width="460" Watermark="Project path"/>
                    <TextBox Width="460" Watermark="Build version"/>

                </StackPanel>

            </Border>

            <!-- CARD: FTP -->
            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">

                <StackPanel Spacing="10">

                    <CheckBox x:Name="CBLoadToFtp"
                              Content="Upload to FTP"
                              FontWeight="Medium"/>

                    <StackPanel Spacing="8"
                                Margin="24,0,0,0"
                                IsVisible="{Binding #CBLoadToFtp.IsChecked}">

                        <TextBox Width="460" Watermark="FTP server"/>
                        <TextBox Width="460" Watermark="Username"/>
                        <TextBox Width="460" Watermark="Password"
                                 PasswordChar="*"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- CARD: PLATFORMS -->
            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">

                <StackPanel Spacing="14">

                    <TextBlock Text="Platforms"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>

                    <!-- PLATFORM ITEMS -->
                    <StackPanel Spacing="12">

                        <!-- Windows x64 -->
                        <StackPanel Spacing="6">
                            <CheckBox Content="Windows x64" x:Name="WinX64"/>

                            <TextBox Width="460"
                                     Watermark="Output path (Windows x64)">

                                <TextBox.IsVisible>
                                    <MultiBinding Converter="{StaticResource AndBoolConverter}">
                                        <Binding ElementName="WinX64" Path="IsChecked"/>
                                        <Binding ElementName="CBLoadToFtp" Path="IsChecked"/>
                                    </MultiBinding>
                                </TextBox.IsVisible>

                            </TextBox>
                        </StackPanel>

                        <!-- Windows arm64 -->
                        <StackPanel Spacing="6">
                            <CheckBox Content="Windows arm64" x:Name="WinArm64"/>

                            <TextBox Width="460"
                                     Watermark="Output path (Windows arm64)">

                                <TextBox.IsVisible>
                                    <MultiBinding Converter="{StaticResource AndBoolConverter}">
                                        <Binding ElementName="WinArm64" Path="IsChecked"/>
                                        <Binding ElementName="CBLoadToFtp" Path="IsChecked"/>
                                    </MultiBinding>
                                </TextBox.IsVisible>

                            </TextBox>
                        </StackPanel>

                        <!-- Linux -->
                        <StackPanel Spacing="6">
                            <CheckBox Content="Linux x64" x:Name="LinuxX64"/>

                            <TextBox Width="460"
                                     Watermark="Output path (Linux x64)">

                                <TextBox.IsVisible>
                                    <MultiBinding Converter="{StaticResource AndBoolConverter}">
                                        <Binding ElementName="LinuxX64" Path="IsChecked"/>
                                        <Binding ElementName="CBLoadToFtp" Path="IsChecked"/>
                                    </MultiBinding>
                                </TextBox.IsVisible>

                            </TextBox>
                        </StackPanel>

                        <!-- Mac -->
                        <StackPanel Spacing="6">
                            <CheckBox Content="MacOS x64" x:Name="MacX64"/>

                            <TextBox Width="460"
                                     Watermark="Output path (MacOS x64)">

                                <TextBox.IsVisible>
                                    <MultiBinding Converter="{StaticResource AndBoolConverter}">
                                        <Binding ElementName="MacX64" Path="IsChecked"/>
                                        <Binding ElementName="CBLoadToFtp" Path="IsChecked"/>
                                    </MultiBinding>
                                </TextBox.IsVisible>

                            </TextBox>
                        </StackPanel>

                        <!-- Android -->
                        <StackPanel Spacing="6">
                            <CheckBox Content="Android"
                                      x:Name="Android"
                                      IsEnabled="False"/>

                            <TextBox Width="460"
                                     Watermark="Keystore / output path (Android)">

                                <TextBox.IsVisible>
                                    <MultiBinding Converter="{StaticResource AndBoolConverter}">
                                        <Binding ElementName="Android" Path="IsChecked"/>
                                        <Binding ElementName="CBLoadToFtp" Path="IsChecked"/>
                                    </MultiBinding>
                                </TextBox.IsVisible>

                            </TextBox>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- ACTION BAR -->
            <Border Background="{DynamicResource SurfaceBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">

                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                    <TextBlock Text="Ready to build"
                               Foreground="{DynamicResource TextMuted}"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="12">

                        <Button Content="Cancel"
                                Width="120"/>

                        <Button Content="Start Build"
                                Width="160"
                                Background="{DynamicResource AccentPrimary}"
                                Foreground="{DynamicResource TextOnAccent}"/>

                    </StackPanel>

                </Grid>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>