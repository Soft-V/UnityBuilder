<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="540"
			 x:Class="UnityBuilder.Views.SecondPage"
			 xmlns:vm="using:UnityBuilder.ViewModels"
			 x:DataType="vm:PagesViewModel">

	<Grid RowDefinitions="*,Auto">

		<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
			<Border Classes="card" Margin="16">

				<StackPanel Spacing="20">

					<StackPanel Spacing="4">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="{DynamicResource PageBuildOptionsTitle}" Classes="page-title"/>
						</StackPanel>
						<TextBlock Text="{DynamicResource PageBuildOptionsCaption}"
								   Classes="caption"/>
					</StackPanel>

					<Border Classes="divider"/>

					<Border Classes="card-elevated">
						<StackPanel Spacing="6">
							<CheckBox Content="{DynamicResource CBComputeHashes}"
									  FontWeight="Medium"
									  IsChecked="{Binding ComputeHashes}"/>
							<TextBlock Text="{DynamicResource CaptionHashInfo}"
									   Classes="caption" Margin="26,0,0,0"/>
						</StackPanel>
					</Border>

					<Border Classes="card-elevated">
						<StackPanel Spacing="14">

							<CheckBox x:Name="CBLoadToFtp"
									  Content="{DynamicResource CBUploadFtp}"
									  FontWeight="Medium"
									  IsChecked="{Binding UploadOnFtp}"/>

							<StackPanel Spacing="12" Margin="0,4,0,0"
										IsVisible="{Binding #CBLoadToFtp.IsChecked}">

								<Grid ColumnDefinitions="*,160">
									<StackPanel Spacing="6">
										<TextBlock Text="{DynamicResource FieldServer}" Classes="field-label"/>
										<TextBox Watermark="ftp.example.com"
												 Text="{Binding FtpServer}"/>
									</StackPanel>
									<StackPanel Grid.Column="1" Spacing="6" Margin="10,0,0,0">
										<TextBlock Text="{DynamicResource FieldPort}" Classes="field-label"/>
										<TextBox Watermark="21" Text="{Binding FtpPort}"/>
									</StackPanel>
								</Grid>

								<Grid ColumnDefinitions="*,*">
									<StackPanel Spacing="6">
										<TextBlock Text="{DynamicResource FieldUsername}" Classes="field-label"/>
										<TextBox Watermark="username"
												 Text="{Binding FtpUsername}"/>
									</StackPanel>
									<StackPanel Grid.Column="1" Spacing="6" Margin="10,0,0,0">
										<TextBlock Text="{DynamicResource FieldPassword}" Classes="field-label"/>
										<TextBox Watermark="••••••••"
												 PasswordChar="●"
												 Text="{Binding FtpPassword}"/>
									</StackPanel>
								</Grid>

								<StackPanel Spacing="10" Orientation="Horizontal">
									<Button Content="{DynamicResource BtnCheckConnection}" Command="{Binding CheckFTPConnection}"/>
									<TextBlock Text="{Binding FtpConnectionLog}"
											   VerticalAlignment="Center"
											   Foreground="{Binding LogColor}"
											   FontWeight="Bold"/>
								</StackPanel>

								<ProgressBar IsIndeterminate="True"
											 IsVisible="{Binding IsChecking}"
											 Foreground="{DynamicResource AccentPrimary}"
											 VerticalAlignment="Center"/>

								<CheckBox Content="{DynamicResource CBDeleteRemote}"
										  FontWeight="Medium"
										  IsChecked="{Binding FtpDeleteOnUpload}"/>

							</StackPanel>
						</StackPanel>
					</Border>

				</StackPanel>
			</Border>
		</ScrollViewer>

		<Border Grid.Row="1" Classes="action-bar" Margin="16,0,16,16">
			<Grid>
				<StackPanel Orientation="Horizontal"
							Spacing="10"
							HorizontalAlignment="Right">
					<Button Content="{DynamicResource BtnBack}" Width="110" Click="Button1_Click"/>
					<Button Content="{DynamicResource BtnNext}" Width="110" Classes="accent-btn" Click="Button_Click"/>
				</StackPanel>
			</Grid>
		</Border>

	</Grid>
</UserControl>
