<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UnityBuilder.Views.SecondPage"
			 xmlns:vm="using:UnityBuilder.ViewModels"
			 x:DataType="vm:PagesViewModel">
    <Grid>
		<!-- ===== FTP ===== -->
		<Border Background="{DynamicResource SurfaceBackground}"
				BorderBrush="{DynamicResource BorderColor}"
				BorderThickness="1"
				VerticalAlignment="Center"
				HorizontalAlignment="Center"
				CornerRadius="12"
				Padding="16">

			<StackPanel Spacing="10">

				<CheckBox Content="Compute hashes"
							FontWeight="Medium"
							IsChecked="{Binding ComputeHashes}"/>

				<CheckBox x:Name="CBLoadToFtp"
							Content="Upload to FTP"
							FontWeight="Medium"
							IsChecked="{Binding UploadOnFtp}"/>

				<StackPanel Spacing="8"
							IsVisible="{Binding #CBLoadToFtp.IsChecked}">

					<TextBox Width="460" Watermark="FTP server" Text="{Binding FtpServer}"/>
					<TextBox Width="460" Watermark="Username" Text="{Binding FtpUsername}"/>
					<TextBox Width="460" Watermark="Password"
								PasswordChar="*" Text="{Binding FtpPassword}"/>
					<TextBox Width="460" Watermark="Port" Text="{Binding FtpPort}"/>
					<CheckBox Content="Delete on upload"
							  FontWeight="Medium" IsChecked="{Binding FtpDeleteOnUpload}"/>

				</StackPanel>

			</StackPanel>

		</Border>

		<!-- ACTION BAR -->
		<Border Background="{DynamicResource SurfaceBackground}"
				BorderBrush="{DynamicResource BorderColor}"
				BorderThickness="1"
				CornerRadius="12"
				VerticalAlignment="Bottom"
				HorizontalAlignment="Stretch"
				Padding="14"
				Margin="6">

			<Grid ColumnDefinitions="*,Auto">

				<TextBlock Text="FTP and hash"
						   VerticalAlignment="Center"
						   Foreground="{DynamicResource TextMuted}"/>

				<StackPanel Grid.Column="1"
							Orientation="Horizontal"
							Spacing="12">

					<Button Content="Previous page" Width="120"
							Click="Button1_Click"/>
					<Button Content="Next page"
							Width="160"
							Classes="accent-btn"
							Click="Button_Click"/>

				</StackPanel>

			</Grid>

		</Border>
	</Grid>
</UserControl>
