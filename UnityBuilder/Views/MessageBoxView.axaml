<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UnityBuilder.Views.MessageBoxView"        
		xmlns:views="clr-namespace:UnityBuilder.Views"
		x:DataType="views:MessageBoxView"
        Width="420"
		Height="120"
		SizeToContent="Height"
		CanResize="False"
		SystemDecorations="None"
		ExtendClientAreaToDecorationsHint="True"
		ExtendClientAreaChromeHints="NoChrome"
		TransparencyLevelHint="Transparent"
		WindowStartupLocation="CenterOwner"
		Background="Transparent">

  <Border Background="{DynamicResource SurfaceBackground}"
			BorderBrush="{DynamicResource BorderColor}"
			BorderThickness="1"
			CornerRadius="12"
			Padding="20">
		<StackPanel Spacing="12">
			<TextBlock Text="{Binding TitleText}"
					   FontSize="14"
					   FontWeight="SemiBold"
					   Foreground="{DynamicResource TextPrimary}" />
			<TextBlock Text="{Binding MessageText}"
					   TextWrapping="Wrap"
					   Foreground="{DynamicResource TextSecondary}"
					   Margin="0,2,0,4" />
			<StackPanel Orientation="Horizontal"
						HorizontalAlignment="Right"
						Spacing="8">
				<Button x:Name="CancelButton"
						Classes="tab-btn"
						VerticalContentAlignment="Center"
						HorizontalContentAlignment="Center"
						Content="{DynamicResource BtnCancel}"
						Height="34"
						Width="96"
						MinWidth="96"
						IsVisible="{Binding IsConfirm}" />
				<Button x:Name="OkButton"
						Classes="accent-btn"
						Content="{DynamicResource BtnOk}"
						Height="34"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center"
						Width="96"
						MinWidth="96" />
			</StackPanel>
		</StackPanel>
	</Border>
</Window>
