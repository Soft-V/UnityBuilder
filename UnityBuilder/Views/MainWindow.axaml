<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnityBuilder.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:views="using:UnityBuilder.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UnityBuilder.Views.MainWindow"
        MinHeight="500"
        MinWidth="600"
        Icon="/Assets/avalonia-logo.ico"
        Title="UnityBuilder">

	<Window.Styles>
		<Style Selector="Border.steps">
			<Setter Property="Height" Value="25"/>
			<Setter Property="Width" Value="25"/>
			<Setter Property="Background" Value="Gray"/>
		</Style>
		<Style Selector="Border.steps.done">
			<Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
		</Style>
	</Window.Styles>
    <!-- ROOT GRID -->
	<Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto, *">

		<StackPanel Spacing="10" Grid.Row="1">
			<Border x:Name="StepOne"
					Classes="steps"/>
			<Border x:Name="StepTwo"
					Classes="steps"/>
			<Border x:Name="StepThree"
					Classes="steps"/>
			<Border x:Name="StepPipline"
					Classes="steps"/>
		</StackPanel>

		<!-- HEADER (fixed) -->
		<Grid Grid.Row="0"
			  Margin="32,20,32,0"
			  Grid.ColumnSpan="2"
			  ColumnDefinitions="*,Auto">

			<TextBlock Text="UN\TY BU\LDER"
					   FontSize="32"
					   FontWeight="SemiBold"
					   Foreground="{DynamicResource TextPrimary}"/>

			<Button Grid.Column="1"
					Classes="toolbar-btn"
					Padding="12,6"
					Click="Button_Click">
				<materialIcons:MaterialIcon Kind="Brightness4"
											Height="25"
											Foreground="{DynamicResource AccentPrimary}"
											Width="25"/>	
			</Button>

		</Grid>
		<TransitioningContentControl Name="ContentControl" Grid.Row="1" Grid.Column="1"/>
	</Grid>
</Window>
