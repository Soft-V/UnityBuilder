<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:UnityBuilder.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
		xmlns:views="using:UnityBuilder.Views"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="UnityBuilder.Views.MainWindow"
		MinHeight="600"
		x:DataType="vm:MainViewModel"
		MinWidth="750"
		Closing="Window_Closing"
		Icon="/Assets/avalonia-logo.ico"
		Title="UnityBuilder">

	<Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto, *">

		<Border Classes="card"
				Grid.Row="1"
				x:Name="StepsBorder"
				IsEnabled="{Binding !BuildIsRunning}"
				Margin="16,16,0,16">

			<StackPanel Spacing="0" Margin="4">
				<TextBlock Text="Steps"
						   Classes="section-title"
						   Margin="6,0,6,10"/>

				<Button Classes="step-row" Click="StepOne_Click">
					<Grid ColumnDefinitions="Auto, *">
						<Border x:Name="StepOne" Classes="steps">
							<TextBlock Text="1"/>
						</Border>
						<StackPanel Grid.Column="1" Spacing="3" Margin="10,0,0,0"
									VerticalAlignment="Center">
							<TextBlock Text="Project" Classes="section-title" x:Name="TBProject"/>
							<TextBlock Text="Unity &amp; paths" Classes="field-label"/>
						</StackPanel>
					</Grid>
				</Button>
				<Border x:Name="StepTwoSeparator"
						Classes="steps"
						Height="24" Width="5"
						HorizontalAlignment="Left"
						Margin="23,0,0,0"/>

				<Button Classes="step-row" Click="StepTwo_Click">
					<Grid ColumnDefinitions="Auto, *">
						<Border x:Name="StepTwo" Classes="steps">
							<TextBlock Text="2"/>
						</Border>
						<StackPanel Grid.Column="1" Spacing="3" Margin="10,0,0,0"
									VerticalAlignment="Center">
							<TextBlock Text="Build options" Classes="section-title" x:Name="TBBuildOptions"/>
							<TextBlock Text="Hashes &amp; FTP" Classes="field-label"/>
						</StackPanel>
					</Grid>
				</Button>
				<Border x:Name="StepThreeSeparator"
						Classes="steps"
						Height="24" Width="5"
						HorizontalAlignment="Left"
						Margin="23,0,0,0"/>

				<Button Classes="step-row" Click="StepThree_Click">
					<Grid ColumnDefinitions="Auto, *">
						<Border x:Name="StepThree" Classes="steps">
							<TextBlock Text="3"/>
						</Border>
						<StackPanel Grid.Column="1" Spacing="3" Margin="10,0,0,0"
									VerticalAlignment="Center">
							<TextBlock Text="Platforms" Classes="section-title" x:Name="TBPlatforms"/>
							<TextBlock Text="Target systems" Classes="field-label"/>
						</StackPanel>
					</Grid>
				</Button>
				<Border x:Name="StepPiplineSeparator"
						Classes="steps"
						Height="24" Width="5"
						HorizontalAlignment="Left"
						Margin="23,0,0,0"/>

				<Button Classes="step-row" Click="StepThree_Click" IsEnabled="False">
					<Grid ColumnDefinitions="Auto, *">
						<Border x:Name="StepPipline" Classes="steps">
							<TextBlock Text="4"/>
						</Border>
						<StackPanel Grid.Column="1" Spacing="3" Margin="10,0,0,0"
									VerticalAlignment="Center">
							<TextBlock Text="Pipeline" Classes="section-title" x:Name="TBPipline"/>
							<TextBlock Text="Build &amp; deploy" Classes="field-label"/>
						</StackPanel>
					</Grid>
				</Button>
			</StackPanel>
		</Border>

		<Grid Grid.Row="0"
			  Margin="32,20,32,0"
			  Grid.ColumnSpan="2"
			  ColumnDefinitions="*,Auto">

			<TextBlock Text="UN/TY BU/LDER"
					   FontSize="32"
					   FontWeight="SemiBold"
					   Foreground="{DynamicResource TextPrimary}"/>

			<StackPanel Orientation="Horizontal"
						Spacing="10"
						HorizontalAlignment="Right">
				<Button Grid.Column="1"
						Classes="toolbar-btn"
						Padding="12,6"
						IsEnabled="{Binding !BuildIsRunning}"
						IsVisible="{Binding ShowUpdateButton}"
						Command="{Binding DownloadAndStartUpdateCommand}">
					<materialIcons:MaterialIcon Kind="Update"
												Height="25"
												Foreground="{DynamicResource WarningColor}"
												Width="25"/>
				</Button>
				<Button Grid.Column="1"
						Classes="toolbar-btn"
						Padding="12,6"
						Command="{Binding SwitchThemeCommand}">
					<materialIcons:MaterialIcon Kind="Brightness4"
												Height="25"
												Foreground="{DynamicResource AccentPrimary}"
												Width="25"/>
				</Button>
			</StackPanel>

		</Grid>
		<TransitioningContentControl Name="ContentControl" Grid.Row="1" Grid.Column="1"/>
	</Grid>
</Window>
