<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="540"
			 x:Class="UnityBuilder.Views.FirstPage"
			 xmlns:vm="using:UnityBuilder.ViewModels"
			 x:DataType="vm:PagesViewModel">

	<Grid RowDefinitions="*,Auto">

		<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
			<Border Classes="card" Margin="16">

				<StackPanel Spacing="20">

					<StackPanel Spacing="4">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="Project Settings" Classes="page-title"/>
						</StackPanel>
						<TextBlock Text="Configure Unity executable and output directories"
								   Classes="caption"/>
					</StackPanel>

					<Border Classes="divider"/>

					<StackPanel Spacing="6">
						<TextBlock Text="Unity Executable" Classes="field-label"/>
						<Grid ColumnDefinitions="*,Auto">
							<TextBox Watermark="Path to Unity.exe / Unity.app"
									 Text="{Binding UnityPath}"/>
							<Button Content="Browse"
									Grid.Column="1" Width="90" Margin="8,0,0,0"
									Classes="accent-btn"
									Command="{Binding ChooseUnityPathCommand}"/>
						</Grid>
					</StackPanel>

					<StackPanel Spacing="6">
						<TextBlock Text="Project Path" Classes="field-label"/>
						<Grid ColumnDefinitions="*,Auto">
							<TextBox Watermark="Folder containing Assets/, ProjectSettings/, etc."
									 Text="{Binding ProjectPath}"/>
							<Button Content="Browse"
									Grid.Column="1" Width="90" Margin="8,0,0,0"
									Classes="accent-btn"
									Command="{Binding ChooseProjectPathCommand}"/>
						</Grid>
					</StackPanel>

					<Grid ColumnDefinitions="200,*">
						<StackPanel Spacing="6">
							<TextBlock Text="Build Version" Classes="field-label"/>
							<TextBox Watermark="1.0.0" Text="{Binding BuildVersion}"/>
						</StackPanel>

						<StackPanel Grid.Column="1" Spacing="6" Margin="12,0,0,0">
							<TextBlock Text="Output Directory" Classes="field-label"/>
							<Grid ColumnDefinitions="*,Auto">
								<TextBox Watermark="Where to save builds"
										 Text="{Binding OutputDirectory}"/>
								<Button Content="Browse"
										Grid.Column="1" Width="90" Margin="8,0,0,0"
										Classes="accent-btn"
										Command="{Binding ChooseOutputPathCommand}"/>
							</Grid>
						</StackPanel>
					</Grid>

					<TextBlock Text="Build name" Classes="field-label"/>
					<TextBox Watermark="Robocad V"
							 Text="{Binding BuildName}"/>

				</StackPanel>
			</Border>
		</ScrollViewer>

		<Border Grid.Row="1" Classes="action-bar">
			<Grid>
				<Border Classes="badge"
						HorizontalAlignment="Left"
						VerticalAlignment="Center">
					<TextBlock Text="Step 1 of 3" Classes="caption"/>
				</Border>
				<Button Content="Next →" Width="130"
						Classes="accent-btn"
						HorizontalAlignment="Right"
						Click="Button_Click"/>
			</Grid>
		</Border>

	</Grid>
</UserControl>
