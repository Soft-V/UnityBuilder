<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.card">
        <Setter Property="Background"       Value="{DynamicResource SurfaceBackground}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="12"/>
        <Setter Property="Padding"          Value="20"/>
    </Style>

    <Style Selector="Border.card-sm">
        <Setter Property="Background"       Value="{DynamicResource SurfaceBackground}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="14"/>
    </Style>

    <Style Selector="Border.card-elevated">
        <Setter Property="Background"       Value="{DynamicResource ElevatedBackground}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="8"/>
        <Setter Property="Padding"          Value="14"/>
    </Style>

    <Style Selector="Border.action-bar">
        <Setter Property="Background"       Value="{DynamicResource SurfaceBackground}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="12"/>
        <Setter Property="Padding"          Value="14,10"/>
        <Setter Property="Margin"           Value="6,6,6,6"/>
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="Background"       Value="{DynamicResource ElevatedBackground}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="20"/>
        <Setter Property="Padding"          Value="10,3"/>
    </Style>

    <Style Selector="Border.tag">
        <Setter Property="Background"       Value="{DynamicResource ElevatedBackground}"/>
        <Setter Property="CornerRadius"     Value="4"/>
        <Setter Property="Padding"          Value="6,2"/>
    </Style>

    <Style Selector="Border.divider">
        <Setter Property="Background"       Value="{DynamicResource BorderColor}"/>
        <Setter Property="Height"           Value="1"/>
        <Setter Property="Margin"           Value="0,4"/>
    </Style>

    <Style Selector="Ellipse.status-dot">
        <Setter Property="Width"            Value="8"/>
        <Setter Property="Height"           Value="8"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</Styles>
