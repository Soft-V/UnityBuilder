<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Dark Theme ──────────────────────────────── -->

    <!-- Backgrounds (deep navy-black) -->
    <SolidColorBrush x:Key="AppBackground"       Color="#09090F" />
    <SolidColorBrush x:Key="SurfaceBackground"   Color="#13131C" />
    <SolidColorBrush x:Key="ElevatedBackground"  Color="#1C1C28" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"         Color="#F1F1F5" />
    <SolidColorBrush x:Key="TextSecondary"       Color="#B8BDD0" />
    <SolidColorBrush x:Key="TextMuted"           Color="#6B7280" />
    <SolidColorBrush x:Key="TextOnAccent"        Color="#FFFFFF" />

    <!-- Highlight -->
    <SolidColorBrush x:Key="HighlightBackground" Color="#2D1A2E" />
    <SolidColorBrush x:Key="HighlightForeground" Color="#F9A8D4" />

    <!-- Accent (pink) -->
    <SolidColorBrush x:Key="AccentPrimary"       Color="#F472B6" />
    <SolidColorBrush x:Key="AccentHover"         Color="#F9A8D4" />
    <SolidColorBrush x:Key="AccentPressed"       Color="#EC4899" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessColor"        Color="#34D399" />
    <SolidColorBrush x:Key="WarningColor"        Color="#FBBF24" />
    <SolidColorBrush x:Key="DangerColor"         Color="#F87171" />
    <SolidColorBrush x:Key="DangerHover"         Color="#FCA5A5" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderColor"         Color="#2A2A38" />
    <SolidColorBrush x:Key="BorderLight"         Color="#35354A" />

    <!-- Scrollbar (visible on dark backgrounds) -->
    <SolidColorBrush x:Key="ScrollThumb"         Color="#44445A" />
    <SolidColorBrush x:Key="ScrollThumbHover"    Color="#6B6B88" />

</ResourceDictionary>
